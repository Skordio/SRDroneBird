{
	"name": "sr_dronebird_website",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite --host",
		"build": "run-p type-check build-only",
		"preview": "vite preview",
		"test:unit": "vitest --environment jsdom --root src/",
		"build-only": "vite build",
		"test": "echo \"Error: no test specified\" && exit 1",
		"prettier:all": "prettier --write .",
		"prettier:checkall": "prettier --check .",
		"eslint:all": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.html",
		"type-check": "vue-tsc --noEmit -p tsconfig.json --composite false"
	},
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^6.7.2",
		"@fortawesome/free-solid-svg-icons": "^6.7.2",
		"@fortawesome/vue-fontawesome": "^3.1.3",
		"@popperjs/core": "^2.11.8",
		"@vitejs/plugin-vue": "^5.2.4",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.7.0",
		"@vueuse/core": "^12.8.2",
		"axios": "^1.13.5",
		"bootstrap": "^5.3.8",
		"bootswatch": "^5.3.8",
		"eventemitter3": "^5.0.4",
		"jquery": "^3.7.1",
		"jsdom": "^26.1.0",
		"pinia": "^3.0.4",
		"video.js": "^8.23.7",
		"vite": "^6.4.1",
		"vitest": "^3.2.4",
		"vue": "^3.5.28",
		"vue-router": "^4.6.4",
		"vue-sidebar-menu": "^5.9.1",
		"vuetify": "^3.11.8"
	},
	"devDependencies": {
		"@openapitools/openapi-generator-cli": "^2.29.0",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.19.11",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"eslint": "^9.39.2",
		"eslint-plugin-html": "^8.1.4",
		"eslint-plugin-vue": "^9.33.0",
		"npm-run-all": "^4.1.5",
		"prettier": "3.5.2",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"videojs-resolution-switcher": "^0.4.2",
		"vite": ">=4.5.6",
		"vue-eslint-parser": "^9.4.3",
    	"vue-tsc": "^2.2.12"
	},
	"eslintConfig": {
		"root": true,
		"parser": "vue-eslint-parser",
		"parserOptions": {
			"parser": "@typescript-eslint/parser",
			"sourceType": "module"
		},
		"plugins": [
			"@typescript-eslint",
			"@vue",
			"html"
		],
		"extends": [
			"eslint:recommended",
			"plugin:@typescript-eslint/eslint-recommended",
			"plugin:@typescript-eslint/recommended",
			"plugin:vue/base"
		],
		"rules": {
			"no-console": "warn",
			"prefer-const": "off",
			"no-var": "off",
			"@typescript-eslint/ban-types": "off",
			"@typescript-eslint/no-inferrable-types": "off",
			"no-empty": "off",
			"no-unsafe-optional-chaining": "warn",
			"@typescript-eslint/no-unused-vars": "off",
			"no-mixed-spaces-and-tabs": "off"
		}
	},
	"prettier": {
		"trailingComma": "es5",
		"tabWidth": 4,
		"useTabs": true,
		"semi": false
	},
	"engines": {
		"node": ">=14",
		"pnpm": ">=7"
	},
	"keywords": [],
	"author": "skordion@hotmail.com",
	"license": "MIT"
}
